    SELECT [a1].[AvailableStylesId], [a1].[StylistsId], [h0].[Id], [h0].[CreatedAt], [h0].[Description], [h0].[IsDeleted], [h0].[ModifiedAt], [h0].[Origin], [h0].[PhotoId], [h0].[PriceTag], [h0].[PromotionalOffer], [h0].[StyleName], [h0].[StylistPortfolioId], [h0].[VideoLinks]
    FROM [AppUserHairStyle] AS [a1]
    INNER JOIN [HairStyles] AS [h0] ON [a1].[AvailableStylesId] = [h0].[Id]
) AS [s] ON [a].[Id] = [s].[StylistsId]
WHERE EXISTS (
    SELECT 1
    FROM [AppUserHairStyle] AS [a0]
    INNER JOIN [HairStyles] AS [h] ON [a0].[AvailableStylesId] = [h].[Id]
    WHERE [a].[Id] = [a0].[StylistsId] AND [h].[Id] = @__hairStyleId_0)
ORDER BY [a].[Id], [s].[AvailableStylesId], [s].[StylistsId]
